# Copy to neo4j.env (gitignored) on the VM and edit before `docker compose up`.
# Do NOT commit real passwords.

# Strong password for the built-in "neo4j" user. Required.
NEO4J_PASSWORD=change-me-to-a-long-random-password

# Public host/IP of the VM, used so Bolt advertises a reachable address.
# Set this to the VM's external IP (or DNS name). Example: 203.0.113.10
NEO4J_ADVERTISED_HOST=your.vm.public.ip

# Memory tuning. Defaults fit a ~1 GB VM. On an Oracle Ampere (e.g. 6-24 GB)
# raise these, e.g. HEAP=2g, PAGECACHE=2g.
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=512m
