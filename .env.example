# ==============================================================================
# Environment Configuration — Copy to .env and fill in values
# ==============================================================================

# --- LLM Provider (Google Gemini) ---
# Get your key from: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key
# Chat model. Free tier limits are per-model (gemini-2.5-flash is often ~20 req/day).
# Each analyze query uses multiple LLM calls. If you hit 429 quota errors, try:
#   GOOGLE_MODEL_NAME=gemini-2.0-flash-lite
# or enable billing: https://ai.google.dev/pricing
GOOGLE_MODEL_NAME=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# --- Groq (optional chat fallback when Gemini quota is hit) ---
# Get a key: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL_NAME=llama-3.3-70b-versatile
# Primary chat provider: google | groq
LLM_PRIMARY=google
# If true, auto-switch to the other provider on 429 / quota errors
LLM_FALLBACK_ENABLED=true

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=graphrag2024

# --- Qdrant ---
# Local (docker-compose):
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Qdrant Cloud (set URL + API key from https://cloud.qdrant.io — overrides host/port):
# QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=codebase_chunks

# --- Ingestion ---
# Path to the codebase directory to analyze
TARGET_CODEBASE_PATH=./sample_codebase
