# Copy to cloudrun.env (gitignored) for local `gcloud run deploy --env-vars-file`.
# Do not commit real keys. Set the same vars on Cloud Run before enabling CI.

GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL_NAME=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL_NAME=llama-3.3-70b-versatile
LLM_PRIMARY=google
LLM_FALLBACK_ENABLED=true
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
QDRANT_URL=https://xxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=codebase_chunks
TARGET_CODEBASE_PATH=./sample_codebase
